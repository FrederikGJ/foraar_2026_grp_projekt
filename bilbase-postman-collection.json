            "body": {
              "mode": "raw",
              "raw": "{\n    \"regionId\": 1,\n    \"street\": \"Test\",\n    \"postalCode\": \"1000\",\n    \"city\": \"KBH\",\n    \"modelId\": 1,\n    \"fuelTypeId\": 1,\n    \"price\": 100000,\n    \"year\": 2020,\n    \"mileageKm\": 10000,\n    \"color\": \"Blå\",\n    \"description\": \"Skal fejle\"\n}"
            },
