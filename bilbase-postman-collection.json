{
  "info": {
    "name": "Bilbase Backend API",
    "description": "Postman collection til test af Bilbase backend endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "token", "value": "" },
    { "key": "listingId", "value": "" },
    { "key": "favoriteId", "value": "" }
