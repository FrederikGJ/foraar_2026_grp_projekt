            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/listings?yearFrom=2018&fuelType=Benzin",
              "host": ["{{baseUrl}}"],
              "path": ["api", "listings"],
              "query": [
                { "key": "yearFrom", "value": "2018" },
                { "key": "fuelType", "value": "Benzin" }
              ]
            }
          }
        },
        {
          "name": "Get Listing by ID",
