            "body": {
              "mode": "raw",
              "raw": "{\n    \"regionId\": 1,\n    \"street\": \"Nørrebrogade 42\",\n    \"postalCode\": \"2200\",\n    \"city\": \"København N\",\n    \"modelId\": 1,\n    \"fuelTypeId\": 1,\n    \"price\": 149999.00,\n    \"year\": 2021,\n    \"mileageKm\": 45000,\n    \"color\": \"Rød\",\n    \"description\": \"Velholdt Toyota Corolla med servicehistorik\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/listings", "host": ["{{baseUrl}}"], "path": ["api", "listings"] }
          }
        },
