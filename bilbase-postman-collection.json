          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/listings/active", "host": ["{{baseUrl}}"], "path": ["api", "listings", "active"] }
          }
        },
        {
          "name": "Get Listings - filter by brand",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/listings?brand=Toyota",
              "host": ["{{baseUrl}}"],
              "path": ["api", "listings"],
              "query": [{ "key": "brand", "value": "Toyota" }]
            }
          }
        },
        {
          "name": "Get Listings - filter by price range",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/listings?priceFrom=50000&priceTo=200000",
              "host": ["{{baseUrl}}"],
              "path": ["api", "listings"],
              "query": [
                { "key": "priceFrom", "value": "50000" },
                { "key": "priceTo", "value": "200000" }
              ]
            }
          }
        },
        {
          "name": "Get Listings - filter by year + fuel",
